  font-size: 0.8rem;
  padding: 0.25rem 0.75rem;
  background: transparent;
  color: var(--color-text);
  border: 1px solid var(--color-border);
  text-decoration: none;
}
.pill:hover {
  background: var(--color-text);
  color: var(--color-bg);
}

.share-bar {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--color-border);
}
.share-label {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--color-text-muted);
}
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem;
  background: none;
  border: 1px solid var(--color-border);
  color: var(--color-text);
  cursor: pointer;
  text-decoration: none;
  font-family: var(--font-body);
  font-size: 0.75rem;
}
.share-btn:hover {
  background: var(--color-text);
  color: var(--color-bg);
}
.copy-feedback {
  font-size: 0.75rem;
}

.post-footer {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 2px solid var(--color-border);
}
.related-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin: 0 0 1rem;
}
.related-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.related-link {
  color: var(--color-text);
  text-decoration: none;
  font-weight: 600;
  border-bottom: 1px solid transparent;
}
.related-link:hover {
  border-bottom-color: var(--color-border);
}

.toc-sidebar {
  flex: 0 0 200px;
  position: sticky;
  top: 2rem;
  height: max-content;
  max-height: calc(100vh - 4rem);
  overflow-y: auto;
}
.toc-title {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin: 0 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
}
.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.toc-item {
  margin-bottom: 0.5rem;
}
.toc-h3 {
  padding-left: 1rem;
}
.toc-link {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  text-decoration: none;
}
.toc-link:hover {
  color: var(--color-text);
}

@media (max-width: 800px) {
  .post-layout {
    flex-direction: column;
  }
  .toc-sidebar {
    position: relative;
    top: 0;
    order: -1;
    border: 1px solid var(--color-border);
    padding: 1rem;
    margin-bottom: 2rem;
  }
}
</style>
